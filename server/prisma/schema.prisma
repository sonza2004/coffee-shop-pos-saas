generator client {
  provider = "prisma-client-js"
}

// =========================
// DATABASE
// =========================
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================
// ENUMS
// =========================

enum UserRole {
  admin
  staff
  customer
}

enum OrderStatus {
  pending
  payment_uploaded
  approved
  rejected
  completed
}

enum PaymentStatus {
  pending
  approved
  rejected
}

enum InventoryType {
  sale
  restock
  adjustment
}

// =========================
// MODELS
// =========================

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(customer)
  createdAt    DateTime @default(now())

  orders       Order[]
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     Float
  stockQty  Int      @default(0)
  imageUrl  String?
  isActive  Boolean  @default(true)

  orderItems    OrderItem[]
  inventoryLogs InventoryLog[]
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  totalAmount Float
  status      OrderStatus @default(pending)
  createdAt   DateTime    @default(now())

  user        User        @relation(fields: [userId], references: [id])
  items       OrderItem[]
  paymentSlip PaymentSlip?
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String
  qty       Int
  price     Float

  order   Order   @relation(fields: [orderId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model PaymentSlip {
  id          String        @id @default(cuid())
  orderId     String        @unique
  imageUrl    String
  status      PaymentStatus @default(pending)
  uploadedAt  DateTime      @default(now())
  reviewedAt  DateTime?

  order       Order         @relation(fields: [orderId], references: [id])
}

model InventoryLog {
  id         String        @id @default(cuid())
  productId  String
  changeQty  Int
  type       InventoryType
  createdAt  DateTime      @default(now())

  product    Product @relation(fields: [productId], references: [id])
}
